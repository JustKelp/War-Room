# WarRoom configuration — copy to .env (local) or set as real env vars (server).

# Flask session signing key (REQUIRED in prod so sessions survive restarts).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to 1 on the server (HTTPS) so the session cookie is marked Secure.
# Leave unset for local http://localhost.
WARROOM_HTTPS=

# Socket.IO async mode. Leave unset locally (defaults to "threading" for
# `python app.py`). On the VM set to "eventlet" to match the gunicorn worker.
WARROOM_ASYNC=

# Share one login across the sports games: point this at StatCheck's users DB.
# If unset, WarRoom uses its own `users` table inside warroom.db.
STATCHECK_USERS_DB=

# SQLite path for WarRoom's own data (pool + daily scores). Defaults to ./warroom.db.
WARROOM_DB=

# Port gunicorn binds (defaults to 5053; keep distinct from StatCheck's port).
PORT=
